# LawKit ortam değişkenleri
# Bu dosya repoya commit'lenir. .env (gerçek değerler) commit'lenmez.

# ─────────── LLM sağlayıcı ───────────
# Şu an: DeepSeek (https://platform.deepseek.com). OpenAI uyumlu API.
# Alternatif sağlayıcıya geçmek için sadece URL + KEY + MODEL değiştir;
# kod tarafında değişiklik gerekmez (adapter generic).
LLM_API_KEY=sk-replace-me
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
# UI etiketi — sağlayıcının istatistik panellerinde görünür.
LLM_SITE_URL=https://lawkit.app
LLM_APP_NAME=LawKit

# Geriye uyumluluk (eski OPENROUTER_* değişkenleri okunmaya devam eder):
# OPENROUTER_API_KEY=...
# OPENROUTER_MODEL=...

# ─────────── Supabase (Tur 2'de devreye girer) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-me
