# LawKit ortam değişkenleri
# Bu dosya repoya commit'lenir. .env (gerçek değerler) commit'lenmez.

# ─────────── OpenRouter (LLM gateway) ───────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me
# Free tier model (DeepSeek V3 — JSON mode + Türkçe iyi).
# Alternatifler: meta-llama/llama-3.3-70b-instruct:free, google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
# OpenRouter'a giden HTTP-Referer + X-Title — public app etiketi.
OPENROUTER_SITE_URL=https://lawkit.app
OPENROUTER_APP_NAME=LawKit

# ─────────── Supabase (auth + db + vector) — Tur 2'de devreye girer ───────────
# https://supabase.com/dashboard/projects → "Project URL" + "anon" key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
# Server-only (Worker secret): RLS bypass eden service-role anahtarı, asla client'a verme.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# ─────────── İstemci tarafı (Vite, public) ───────────
# Sadece Supabase URL + anon key client'ta görünebilir. Diğerleri server-only.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-me
