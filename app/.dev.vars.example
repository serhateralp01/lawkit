# LawKit .dev.vars — API anahtarlari
# Bu dosyayi .dev.vars olarak kopyalayip kendi anahtarlarinizi girin.

# ── Supabase ──
SUPABASE_URL=https://nxlnnuznggdyuaodczxb.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Provider (seceneklerden birini secin) ──

# Secenek 1: OpenRouter (onerilen — tek hesap, 200+ model)
# Kayit: https://openrouter.ai
# Avantaj: DeepSeek, Claude, GPT tek API uzerinden, fatura tek yerden
LLM_API_KEY=sk-or-v1-your-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat-v3-0324

# Secenek 2: DeepSeek Dogrudan API
# Kayit: https://platform.deepseek.com
# Avantaj: En ucuz DeepSeek fiyati, latency dusuk
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# Secenek 3: Groq (hizli inference, free tier var)
# Kayit: https://console.groq.com
# Avantaj: En hizli token/s, Llama modellerinde iyi Turkce
# LLM_API_KEY=gsk_your-key
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Secenek 4: Together AI (ucuz open-source modeller)
# Kayit: https://api.together.ai
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
